{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}/build/AuraShell.sln",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/m",
                "/nologo"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        },
        {
            "label": "run-aurashell",
            "type": "shell",
            "command": "${workspaceFolder}/build/Release/AuraShell.exe",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}

